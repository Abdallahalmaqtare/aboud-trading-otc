# ════════════════════════════════════════════════════════════
# Aboud Trading Bot OTC v1.0 - متغيرات البيئة
# ════════════════════════════════════════════════════════════
# انسخ هذا الملف إلى .env وأضف قيمك
# لا ترفع ملف .env أبداً إلى GitHub!
# ════════════════════════════════════════════════════════════

# ─── التيليغرام (إلزامي) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
ADMIN_USER_IDS=123456789

# ─── Pocket Option SSID (إلزامي للتحليل التلقائي) ────────
# كيفية الحصول على SSID - خطوة بخطوة:
# 1. افتح pocketoption.com في المتصفح (Chrome/Firefox)
# 2. سجّل الدخول إلى حسابك
# 3. اضغط F12 لفتح أدوات المطور
# 4. انتقل إلى تبويب Network (الشبكة)
# 5. في مربع الفلتر، اكتب: WS (أو WebSocket)
# 6. أعد تحميل الصفحة (F5)
# 7. ستجد اتصالاً بـ: api-l.po.market أو api-eu.po.market
# 8. انقر على الاتصال → تبويب Messages
# 9. ابحث عن رسالة تبدأ بـ: 42["auth",{"session":"...
# 10. انسخ الرسالة بالكامل وضعها هنا
#
# مثال على الصيغة الصحيحة:
# POCKET_OPTION_SSID=42["auth",{"session":"abc123xyz","isDemo":1,"uid":987654,"platform":1}]
POCKET_OPTION_SSID=

# هل تستخدم الحساب التجريبي؟ (1=تجريبي, 0=حقيقي)
# يُنصح بالبدء بالحساب التجريبي للاختبار
POCKET_OPTION_IS_DEMO=1

# ─── قاعدة البيانات ────────────────────────────────────────
# اتركه فارغاً لاستخدام SQLite المحلي
# أو أضف رابط PostgreSQL للنشر السحابي
DATABASE_URL=

# ─── إعدادات البوت ─────────────────────────────────────────
BOT_UTC_OFFSET=3
PORT=10000
WEBHOOK_SECRET=aboud_trading_secret_2024
SIGNALS_ENABLED=true
DEBUG=false

# ─── التقرير اليومي ────────────────────────────────────────
DAILY_REPORT_HOUR=18

# ─── Render.com (للنشر السحابي) ────────────────────────────
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
