// =====================================================
// ABOUD TRADING BOT PRO - Pine Script v6.0 (HIGH WINRATE)
// =====================================================
// Changes vs v5.2:
//   - REMOVED weak indicators: RSI threshold, Bollinger Bands,
//     Stoch RSI, Candle body ratio
//   - KEPT strong indicators: EMA alignment, EMA200 trend,
//     MACD momentum, Supertrend, ADX, Higher-TF (1H)
//   - ADDED stronger indicators: Volume confirmation,
//     Strong close position, ROC momentum,
//     Price pullback to EMA21
//   - MANDATORY HARD GATES: ADX > 25 AND 1H alignment
//     (a signal is only sent if both gates pass)
//   - target_entry_time = time_close (immediate next candle)
// =====================================================

//@version=5
indicator("Aboud Trading PRO 15M v6", overlay=true, shorttitle="ABOUD PRO v6")

// ───── Inputs ─────
ema_fast_len   = input.int(9,   "EMA Fast",   minval=3,   maxval=50,  group="📊 EMA")
ema_mid_len    = input.int(21,  "EMA Mid",    minval=10,  maxval=100, group="📊 EMA")
ema_slow_len   = input.int(50,  "EMA Slow",   minval=20,  maxval=200, group="📊 EMA")
ema_trend_len  = input.int(200, "EMA Trend",  minval=100, maxval=400, group="📊 EMA")

macd_fast      = input.int(12, "MACD Fast",   minval=5,  maxval=30, group="📉 MACD")
macd_slow      = input.int(26, "MACD Slow",   minval=15, maxval=50, group="📉 MACD")
macd_signal    = input.int(9,  "MACD Signal", minval=3,  maxval=20, group="📉 MACD")

st_period      = input.int(10,   "ST Period",     minval=5,   maxval=30,  group="🔄 Supertrend")
st_multiplier  = input.float(2.0, "ST Multiplier", minval=1.0, maxval=5.0, step=0.1, group="🔄 Supertrend")

adx_len        = input.int(14,    "ADX Period",       minval=5,  maxval=30, group="💪 ADX (MANDATORY)")
adx_min        = input.float(25,  "ADX Min (HARD)",   minval=15, maxval=40, group="💪 ADX (MANDATORY)")

vol_len        = input.int(20,    "Volume SMA",      minval=5,  maxval=50, group="📢 Volume")
vol_mult       = input.float(1.2, "Volume Multiplier",minval=1.0,maxval=3.0, step=0.1, group="📢 Volume")

roc_len        = input.int(9,     "ROC Length",       minval=3,  maxval=20, group="⚡ Momentum")
roc_min        = input.float(0.05,"ROC Min %",        minval=0.01,maxval=1.0, step=0.01, group="⚡ Momentum")

strong_close   = input.float(0.3, "Strong Close Zone",minval=0.1, maxval=0.5, step=0.05, group="🕯️ Candle")

pullback_bars  = input.int(3, "Pullback Lookback",  minval=2, maxval=10, group="🎯 Pullback")
pullback_max   = input.float(0.3, "Max Pullback ATR",minval=0.1, maxval=1.0, step=0.05, group="🎯 Pullback")
atr_len        = input.int(14,    "ATR Period",     minval=5, maxval=30, group="🎯 Pullback")

min_score      = input.int(6,  "Min Score (of 8)", minval=4, maxval=8, group="🎯 Score")
cooldown_bars  = input.int(3, "Cooldown bars",     minval=1, maxval=10, group="🎯 Score")

show_signals   = input.bool(true, "Arrows",     group="🎨 Display")
show_ema       = input.bool(true, "EMAs",       group="🎨 Display")
show_supertrend= input.bool(true, "Supertrend", group="🎨 Display")
show_score     = input.bool(true, "Score Table",group="🎨 Display")
webhook_secret = input.string("aboud_trading_secret_2024", "Secret", group="🔔 Alert")

// ═══════════════════════ CALCULATIONS ═══════════════════════

// 1. EMA alignment (9 > 21 > 50)
ema_fast   = ta.ema(close, ema_fast_len)
ema_mid    = ta.ema(close, ema_mid_len)
ema_slow   = ta.ema(close, ema_slow_len)
ema_trend  = ta.ema(close, ema_trend_len)

score_ema_call   = ema_fast > ema_mid and ema_mid > ema_slow ? 1 : 0
score_ema_put    = ema_fast < ema_mid and ema_mid < ema_slow ? 1 : 0

// 2. EMA200 trend filter
score_trend_call = close > ema_trend ? 1 : 0
score_trend_put  = close < ema_trend ? 1 : 0

// 3. MACD histogram momentum
[macd_line, signal_line, hist_val] = ta.macd(close, macd_fast, macd_slow, macd_signal)
score_macd_call = hist_val > 0 and hist_val > hist_val[1] ? 1 : 0
score_macd_put  = hist_val < 0 and hist_val < hist_val[1] ? 1 : 0

// 4. Supertrend
[st_line, st_dir] = ta.supertrend(st_multiplier, st_period)
st_bullish = st_dir < 0
st_bearish = st_dir > 0
score_st_call = st_bullish ? 1 : 0
score_st_put  = st_bearish ? 1 : 0

// 5. ADX (MANDATORY GATE)
dmi_plus  = ta.change(ta.highest(high, 1))
dmi_minus = -ta.change(ta.lowest(low, 1))
tr_val    = ta.tr(true)
plus_dm   = dmi_plus > dmi_minus and dmi_plus > 0 ? dmi_plus : 0
minus_dm  = dmi_minus > dmi_plus and dmi_minus > 0 ? dmi_minus : 0
smoothed_tr    = ta.rma(tr_val, adx_len)
smoothed_plus  = ta.rma(plus_dm, adx_len)
smoothed_minus = ta.rma(minus_dm, adx_len)
plus_di  = smoothed_tr != 0 ? (smoothed_plus / smoothed_tr) * 100 : 0
minus_di = smoothed_tr != 0 ? (smoothed_minus / smoothed_tr) * 100 : 0
dx       = (plus_di + minus_di) != 0 ? math.abs(plus_di - minus_di) / (plus_di + minus_di) * 100 : 0
adx_val  = ta.rma(dx, adx_len)

adx_ok_call = adx_val >= adx_min and plus_di > minus_di
adx_ok_put  = adx_val >= adx_min and minus_di > plus_di
score_adx_call = adx_ok_call ? 1 : 0
score_adx_put  = adx_ok_put  ? 1 : 0

// 6. Higher timeframe (1H) alignment (MANDATORY GATE)
ema_1h_fast  = request.security(syminfo.tickerid, "60", ta.ema(close, 9))
ema_1h_slow  = request.security(syminfo.tickerid, "60", ta.ema(close, 21))
ema_1h_trend = request.security(syminfo.tickerid, "60", ta.ema(close, 50))
mtf_ok_call = ema_1h_fast > ema_1h_slow and close > ema_1h_trend
mtf_ok_put  = ema_1h_fast < ema_1h_slow and close < ema_1h_trend
score_mtf_call = mtf_ok_call ? 1 : 0
score_mtf_put  = mtf_ok_put  ? 1 : 0

// 7. Volume confirmation (NEW - stronger than candle body alone)
vol_avg = ta.sma(volume, vol_len)
vol_ok = volume > vol_avg * vol_mult
score_vol_call = vol_ok and close > open ? 1 : 0
score_vol_put  = vol_ok and close < open ? 1 : 0

// 8. Strong close position (NEW)
//    Close in the top 30% of range = bullish; bottom 30% = bearish
candle_range = high - low
close_pos = candle_range > 0 ? (close - low) / candle_range : 0.5
score_close_call = close_pos >= (1 - strong_close) ? 1 : 0
score_close_put  = close_pos <= strong_close ? 1 : 0

// 9. ROC momentum (NEW - extra momentum check, not scored but used in gate)
roc_val = ta.roc(close, roc_len)
roc_ok_call = roc_val >= roc_min
roc_ok_put  = roc_val <= -roc_min

// 10. Price pullback to EMA21 (NEW - avoid chasing tops/bottoms)
//     At least once in the last N bars, price was within X*ATR of EMA21
atr_val = ta.atr(atr_len)
near_ema21 = math.abs(close - ema_mid) <= atr_val * pullback_max
pullback_call = false
pullback_put  = false
for i = 1 to pullback_bars
    if math.abs(close[i] - ema_mid[i]) <= atr_val[i] * pullback_max
        if close[i] <= ema_mid[i]
            pullback_call := true
        if close[i] >= ema_mid[i]
            pullback_put := true

// ═══════════════════════ SCORE TOTALS ═══════════════════════
// Only 8 scored components (the stronger ones)
call_score = score_ema_call + score_trend_call + score_macd_call + score_st_call + score_adx_call + score_mtf_call + score_vol_call + score_close_call
put_score  = score_ema_put  + score_trend_put  + score_macd_put  + score_st_put  + score_adx_put  + score_mtf_put  + score_vol_put  + score_close_put

// ═══════════════════════ MANDATORY GATES ═══════════════════════
// A signal is only valid if:
//   - Score >= min_score
//   - ADX gate passes (strong trend)
//   - 1H MTF alignment passes
//   - ROC momentum confirms
gate_call = call_score >= min_score and adx_ok_call and mtf_ok_call and roc_ok_call
gate_put  = put_score  >= min_score and adx_ok_put  and mtf_ok_put  and roc_ok_put

call_signal = gate_call
put_signal  = gate_put

var int bars_since_call = 999
var int bars_since_put  = 999
bars_since_call := bars_since_call + 1
bars_since_put  := bars_since_put  + 1

new_call = call_signal and not call_signal[1] and bars_since_call >= cooldown_bars
new_put  = put_signal  and not put_signal[1]  and bars_since_put  >= cooldown_bars

if new_call
    bars_since_call := 0
if new_put
    bars_since_put := 0

call_disappeared = not call_signal and call_signal[1]
put_disappeared  = not put_signal  and put_signal[1]

// target = next candle open (immediate)
next_entry_time = time_close

// ═══════════════════════ PLOTTING ═══════════════════════
plot(show_ema ? ema_fast  : na, "EMA 9",   color=color.new(color.aqua,   0), linewidth=1)
plot(show_ema ? ema_mid   : na, "EMA 21",  color=color.new(color.blue,   0), linewidth=2)
plot(show_ema ? ema_slow  : na, "EMA 50",  color=color.new(color.orange, 0), linewidth=2)
plot(show_ema ? ema_trend : na, "EMA 200", color=color.new(color.purple, 0), linewidth=3)
st_color = st_bullish ? color.new(color.green, 20) : color.new(color.red, 20)
plot(show_supertrend ? st_line : na, "ST", color=st_color, linewidth=2, style=plot.style_linebr)
plotshape(show_signals and new_call, "CALL", style=shape.triangleup,   location=location.belowbar, color=color.new(color.green, 0), size=size.normal, text="CALL")
plotshape(show_signals and new_put,  "PUT",  style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0),   size=size.normal, text="PUT")
bgcolor(call_signal ? color.new(color.green, 94) : put_signal ? color.new(color.red, 94) : na)

// ═══════════════════════ SCORE TABLE ═══════════════════════
var table t = table.new(position.top_right, 3, 12, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast and show_score
    table.cell(t, 0, 0, "ABOUD v6",  text_color=color.white, bgcolor=color.new(color.blue, 30), text_size=size.small)
    table.cell(t, 1, 0, "CALL",      text_color=color.green, bgcolor=color.new(color.blue, 30), text_size=size.small)
    table.cell(t, 2, 0, "PUT",       text_color=color.red,   bgcolor=color.new(color.blue, 30), text_size=size.small)
    table.cell(t, 0, 1, "EMA align", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 1, str.tostring(score_ema_call),   text_color=score_ema_call   > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 1, str.tostring(score_ema_put),    text_color=score_ema_put    > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 2, "EMA200",    text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 2, str.tostring(score_trend_call), text_color=score_trend_call > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 2, str.tostring(score_trend_put),  text_color=score_trend_put  > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 3, "MACD",      text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 3, str.tostring(score_macd_call),  text_color=score_macd_call  > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 3, str.tostring(score_macd_put),   text_color=score_macd_put   > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 4, "ST",        text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 4, str.tostring(score_st_call),    text_color=score_st_call    > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 4, str.tostring(score_st_put),     text_color=score_st_put     > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 5, "ADX*",      text_color=color.yellow, text_size=size.tiny)
    table.cell(t, 1, 5, str.tostring(score_adx_call),   text_color=score_adx_call   > 0 ? color.green : color.red, text_size=size.tiny)
    table.cell(t, 2, 5, str.tostring(score_adx_put),    text_color=score_adx_put    > 0 ? color.green : color.red, text_size=size.tiny)
    table.cell(t, 0, 6, "1H MTF*",   text_color=color.yellow, text_size=size.tiny)
    table.cell(t, 1, 6, str.tostring(score_mtf_call),   text_color=score_mtf_call   > 0 ? color.green : color.red, text_size=size.tiny)
    table.cell(t, 2, 6, str.tostring(score_mtf_put),    text_color=score_mtf_put    > 0 ? color.green : color.red, text_size=size.tiny)
    table.cell(t, 0, 7, "Volume",    text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 7, str.tostring(score_vol_call),   text_color=score_vol_call   > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 7, str.tostring(score_vol_put),    text_color=score_vol_put    > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 8, "Close pos", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 8, str.tostring(score_close_call), text_color=score_close_call > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 8, str.tostring(score_close_put),  text_color=score_close_put  > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 9, "TOTAL",     text_color=color.yellow, bgcolor=color.new(color.blue, 50), text_size=size.small)
    table.cell(t, 1, 9, str.tostring(call_score)+"/8",  text_color=call_score >= min_score ? color.green : color.gray, bgcolor=color.new(color.blue, 50), text_size=size.small)
    table.cell(t, 2, 9, str.tostring(put_score)+"/8",   text_color=put_score  >= min_score ? color.green : color.gray, bgcolor=color.new(color.blue, 50), text_size=size.small)
    sig = call_signal ? "🟢 CALL("+str.tostring(call_score)+")" : put_signal ? "🔴 PUT("+str.tostring(put_score)+")" : "⚪ NONE"
    table.cell(t, 0, 10, "Signal",   text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 10, sig,        text_color=color.white, text_size=size.tiny)
    table.cell(t, 2, 10, "",         text_size=size.tiny)
    table.cell(t, 0, 11, "ADX/ROC",  text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 11, str.tostring(adx_val,"#.#")+"/"+str.tostring(roc_val,"#.##"), text_color=color.white, text_size=size.tiny)
    table.cell(t, 2, 11, "",         text_size=size.tiny)

// ═══════════════════════ ALERTS ═══════════════════════
if new_call
    a = '{"secret":"'+webhook_secret+'","pair":"'+syminfo.ticker+'","direction":"CALL","action":"SIGNAL","signal_score":'+str.tostring(call_score)+',"target_entry_time":'+str.tostring(next_entry_time)+',"signal_time":'+str.tostring(time_close)+',"signal_close":'+str.tostring(close)+',"indicators":{"ema_fast":'+str.tostring(ema_fast)+',"ema_mid":'+str.tostring(ema_mid)+',"ema_slow":'+str.tostring(ema_slow)+',"ema200":'+str.tostring(ema_trend)+',"macd_hist":'+str.tostring(hist_val)+',"supertrend":"UP","adx":'+str.tostring(adx_val)+',"roc":'+str.tostring(roc_val)+',"volume":'+str.tostring(volume)+'}}'
    alert(a, alert.freq_once_per_bar)

if new_put
    a = '{"secret":"'+webhook_secret+'","pair":"'+syminfo.ticker+'","direction":"PUT","action":"SIGNAL","signal_score":'+str.tostring(put_score)+',"target_entry_time":'+str.tostring(next_entry_time)+',"signal_time":'+str.tostring(time_close)+',"signal_close":'+str.tostring(close)+',"indicators":{"ema_fast":'+str.tostring(ema_fast)+',"ema_mid":'+str.tostring(ema_mid)+',"ema_slow":'+str.tostring(ema_slow)+',"ema200":'+str.tostring(ema_trend)+',"macd_hist":'+str.tostring(hist_val)+',"supertrend":"DOWN","adx":'+str.tostring(adx_val)+',"roc":'+str.tostring(roc_val)+',"volume":'+str.tostring(volume)+'}}'
    alert(a, alert.freq_once_per_bar)

if call_disappeared
    alert('{"secret":"'+webhook_secret+'","pair":"'+syminfo.ticker+'","direction":"CALL","action":"CANCEL"}', alert.freq_once_per_bar)

if put_disappeared
    alert('{"secret":"'+webhook_secret+'","pair":"'+syminfo.ticker+'","direction":"PUT","action":"CANCEL"}', alert.freq_once_per_bar)
